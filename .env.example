# GEMINI_API_KEY: Required for Gemini AI API calls (AI Summarization)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq API calls (AI Classification)
GROQ_API_KEY="MY_GROQ_API_KEY"

# MISTRAL_API_KEY: Required for Mistral API calls (Chatbot)
MISTRAL_API_KEY="MY_MISTRAL_API_KEY"

# HF_TOKEN: Required for Hugging Face API calls (Embeddings)
HF_TOKEN="MY_HF_TOKEN"

# OPENROUTER_API_KEY: Required for OpenRouter API calls (Fallback)
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
